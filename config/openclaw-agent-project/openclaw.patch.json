      {
        "id": "router-agent",
        "name": "router-agent",
        "description": "Telegram and Slack user-facing orchestration agent. Use the strongest configured OpenAI model to understand the user request, broadcast normal work to all configured purpose agents with sessions_spawn, stream useful subagent results back to the user as they arrive, ask targeted follow-up questions to subagents when their outputs are incomplete or conflicting, and finish with a clearly labeled integrated answer. Do not wait for every subagent before helping the user; synthesize when enough evidence exists or the policy deadline is reached. Treat user comments before the integrated answer as updates to the active orchestration, forwarding named or relevant comments to the right subagent. Never do repository, shell, filesystem, or web work directly in router-agent; delegate that work. Never answer as default, web, voice-agent, or claudeclaw.",
        "workspace": "/home/yasu/.openclaw/workspaces/router-agent",
        "model": {
          "primary": "openai/gpt-5.5",
          "fallbacks": [
            "openai/gpt-5.4-mini"
          ]
        },
        "thinkingDefault": "medium",
        "contextInjection": "never",
        "bootstrapMaxChars": 4000,
        "bootstrapTotalMaxChars": 6000,
        "skills": [
          "channel-router",
          "intent-classifier",
          "policy-checker",
          "handoff-summarizer",
          "audit-logger"
        ],
        "memorySearch": {
          "enabled": true,
          "sources": [
            "memory"
          ],
          "extraPaths": [
            "/home/yasu/.openclaw/workspaces/router-agent/policy"
          ]
        },
        "contextLimits": {
          "memoryGetMaxChars": 12000,
          "toolResultMaxChars": 12000,
          "postCompactionMaxChars": 8000
        },
        "subagents": {
          "delegationMode": "prefer",
          "allowAgents": [
            "work-cisco",
            "azabu-corporate",
            "personal",
            "coding",
            "foxcale-advisor",
            "foxcale-coding",
            "learning-kb"
