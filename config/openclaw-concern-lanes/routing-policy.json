        ]
      }
    },
    {
      "id": "learning-kb",
      "priority": 40,
      "selected_agent": "learning-kb",
      "requested_action_default": "answer",
      "sensitivity_default": "low",
      "routing_reason": "Learning, reading, certification, or knowledge-base context (self-study)",
      "match": {
        "any_keywords": [
          "学習",
          "ナレッジベース",
          "読書",
